      <aliases enabled='yes' />
      <column caption='Senior label' datatype='string' name='[Calculation_0490668001173504]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF  [SeniorCitizen]= 1 &#13;&#10;THEN &quot;Senior&quot; &#13;&#10;ELSE &quot;No Senior&quot; &#13;&#10;END' />
      </column>
      <column caption='Ratio Fiber vs DSL' datatype='real' name='[Calculation_0652021949550592]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM(IF [descripcion (dim!tipo!internet)] = &quot;Fiber optic&quot; THEN [Churn_num] ELSE 0 END) &#13;&#10; / SUM(IF [descripcion (dim!tipo!internet)] = &quot;Fiber optic&quot; THEN 1 ELSE 0 END))&#13;&#10;/&#13;&#10;(SUM(IF [descripcion (dim!tipo!internet)] = &quot;DSL&quot; THEN [Churn_num] ELSE 0 END) &#13;&#10; / SUM(IF [descripcion (dim!tipo!internet)] = &quot;DSL&quot; THEN 1 ELSE 0 END))' />
      </column>
      <column caption='Seg1 Cargo alto mes a mes' datatype='real' name='[Calculation_0652021988638721]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [MonthlyCharges] &gt; 65 &#13;&#10;    AND [descripcion (dim!tipo!contrato)] = &quot;Month-to-month&quot; &#13;&#10;    AND [Churn] = &quot;Yes&quot; &#13;&#10;    THEN [MonthlyCharges] ELSE 0 END)' />
      </column>
      <column caption='Seg2 Fiber electronic check' datatype='real' name='[Calculation_0652021988896770]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [descripcion (dim!tipo!internet)] = &quot;Fiber optic&quot; &#13;&#10;    AND [descripcion (dim!metodo!pago)] = &quot;Electronic check&quot; &#13;&#10;    AND [Churn] = &quot;Yes&quot; &#13;&#10;    THEN [MonthlyCharges] ELSE 0 END)' />
      </column>
      <column caption='Seg3 Nuevos sin servicios' datatype='real' name='[Calculation_0652021989040131]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [tenure] &lt;= 12 &#13;&#10;    AND [n_servicios] &lt;= 1 &#13;&#10;    AND [Churn] = &quot;Yes&quot; &#13;&#10;    THEN [MonthlyCharges] ELSE 0 END)' />
      </column>
      <column caption='Tasa de cancelación' datatype='real' name='[Calculation_0675384032018432]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Churn_num]) / COUNT([cliente_id]))' />
      </column>
      <column caption='Total cancelados' datatype='integer' name='[Calculation_0675384032202753]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Churn_num])' />
      </column>
      <column caption='Total activos' datatype='integer' name='[Calculation_0675384032313346]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([cliente_id]) - SUM([Churn_num])' />
      </column>
      <column caption='% Activos' datatype='real' name='[Calculation_0675384032555011]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - (SUM([Churn_num]) / COUNT([cliente_id]))' />
      </column>
      <column caption='Revenue mensual total' datatype='real' name='[Calculation_0675384032669700]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([MonthlyCharges])' />
      </column>
      <column caption='Revenue en riesgo' datatype='real' name='[Calculation_0675384032792581]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Churn] = &quot;Yes&quot; THEN [MonthlyCharges] ELSE 0 END)' />
      </column>
      <column caption='% Revenue en riesgo' datatype='real' name='[Calculation_0675384032899078]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Churn] = &quot;Yes&quot; THEN [MonthlyCharges] ELSE 0 END)&#13;&#10;/ SUM([MonthlyCharges])' />
      </column>
      <column caption='Cargo promedio cancelados' datatype='real' name='[Calculation_0675384033021959]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [Churn] = &quot;Yes&quot; THEN [MonthlyCharges] END)' />
      </column>
      <column caption='Cargo promedio activos' datatype='real' name='[Calculation_0675384033144840]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [Churn] = &quot;No&quot; THEN [MonthlyCharges] END)' />
      </column>
      <column caption='Tenure promedio cancelados' datatype='real' name='[Calculation_0675384033292297]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [Churn] = &quot;Yes&quot; THEN [tenure] END)' />
      </column>
      <column caption='Tenure promedio activos' datatype='real' name='[Calculation_0675384033386506]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [Churn] = &quot;No&quot; THEN [tenure] END)' />
      </column>
      <column caption='Clientes en segmento riesgo' datatype='integer' name='[Calculation_0675384033542155]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([segmento_riesgo])' />
      </column>
      <column caption='Revenue segmento riesgo' datatype='real' name='[Calculation_0675384033624076]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [segmento_riesgo] = 1 AND [Churn] = &quot;Yes&quot;&#13;&#10;    THEN [MonthlyCharges] ELSE 0 END)' />
      </column>
      <column caption='% Revenue segmento riesgo' datatype='real' name='[Calculation_0675384033771533]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [segmento_riesgo] = 1 AND [Churn] = &quot;Yes&quot;&#13;&#10;    THEN [MonthlyCharges] ELSE 0 END)&#13;&#10;/&#13;&#10;SUM(IF [Churn] = &quot;Yes&quot; THEN [MonthlyCharges] ELSE 0 END)' />
      </column>
      <column caption='Segmento cliente' datatype='string' name='[Calculation_0675384033853454]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Churn] = &quot;Yes&quot; THEN &quot;Cancelado&quot; ELSE &quot;Activo&quot; END' />
      </column>
      <column caption='Label tasa cancelación' datatype='string' name='[Calculation_0675384033943567]' role='measure' type='nominal'>
        <calculation class='tableau' formula='STR(ROUND(SUM([Churn_num]) / COUNT([cliente_id]) * 100, 2)) + &quot;%&quot;' />
      </column>
      <column datatype='string' name='[Churn]' role='dimension' type='nominal' />
      <column caption='Churn num' datatype='integer' name='[Churn_num]' role='dimension' type='ordinal' />
      <column datatype='real' default-format='p0.00%' name='[Cálculo1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([cliente_id (dim!cliente)]) / TOTAL(COUNT([cliente_id (dim!cliente)]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column datatype='real' default-format='p0.00%' name='[Cálculo2]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([cliente_id (dim!cliente)]) / TOTAL(COUNT([cliente_id (dim!cliente)]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Monthly Charges' datatype='real' name='[MonthlyCharges]' role='measure' type='quantitative' />
      <column caption='Paperless Billing' datatype='string' name='[PaperlessBilling]' role='dimension' type='nominal' />
      <column caption='Senior Citizen' datatype='integer' name='[SeniorCitizen]' role='measure' type='quantitative' />
