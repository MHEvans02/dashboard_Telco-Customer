    <worksheet name='Distribución de clientes'>
      <table>
        <view>
          <datasources>
            <datasource caption='telco_modelo' name='federated.0t3rs4o076bamk12xiqri16yhpuz' />
          </datasources>
          <datasource-dependencies datasource='federated.0t3rs4o076bamk12xiqri16yhpuz'>
            <column caption='Segmento cliente' datatype='string' name='[Calculation_0675384033853454]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Churn] = &quot;Yes&quot; THEN &quot;Cancelado&quot; ELSE &quot;Activo&quot; END' />
            </column>
            <column datatype='string' name='[Churn]' role='dimension' type='nominal' />
            <column-instance column='[Churn]' derivation='Attribute' name='[attr:Churn:nk]' pivot='key' type='nominal' />
            <column caption='Cliente Id (Dim!Cliente)' datatype='string' name='[cliente_id (dim!cliente)]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_0675384033853454]' derivation='None' name='[none:Calculation_0675384033853454:nk]' pivot='key' type='nominal' />
            <column-instance column='[Churn]' derivation='None' name='[none:Churn:nk]' pivot='key' type='nominal' />
            <column-instance column='[cliente_id (dim!cliente)]' derivation='Count' name='[pcto:cnt:cliente_id (dim!cliente):qk]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Rows' type='PctTotal' />
            </column-instance>
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
